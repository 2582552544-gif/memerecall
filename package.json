{
  "name": "memerecall",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "analyze:will": "bun run scripts/run_kol_analysis_demo.ts 0xWilliam888",
    "timeline:will": "bun run scripts/run_timeline_demo.ts 0xWilliam888",
    "invest:will": "bun run scripts/run_social_investment_demo.ts 0xWilliam888",
    "watch:demo": "bun run scripts/run_token_watch_demo.ts",
    "watch:test-telegram": "bun run scripts/run_telegram_test_card.ts",
    "hermes:setup": "bash scripts/hermes_setup.sh",
    "hermes:chat": "bash scripts/hermes_chat.sh",
    "hermes:cron:watch": "bash scripts/hermes_create_token_watch_cron.sh",
    "report:will": "bun run scripts/run_full_report_demo.ts 0xWilliam888",
    "leaderboard:run": "bun run scripts/run_leaderboard_demo.ts 10"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/node": "^24.6.0",
    "turbo": "^2.7.4",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "openai": "^6.34.0"
  }
}
